    "@types/node": "^22.9.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "aws-cdk": "^2.169.0",
    "cdk-opennext": "^0.5.6",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
