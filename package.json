{
  "name": "rapidread",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "ingest": "tsx scripts/ingest.ts",
    "enrich": "tsx scripts/enrich.ts",
    "seed-demo-data": "tsx scripts/seed-demo-data.ts",
    "build:open-next": "next build && open-next build",
    "cdk": "cdk --app 'tsx infra/bin/news-recommender.ts'",
    "cdk:deploy": "npm run build:open-next && npm run cdk deploy -- --all",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.693.0",
    "@aws-sdk/client-dynamodb": "^3.693.0",
    "@aws-sdk/client-s3": "^3.693.0",
    "@aws-sdk/lib-dynamodb": "^3.693.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.53.1",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "aws-cdk-lib": "^2.169.0",
    "aws-jwt-verify": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "constructs": "^10.4.2",
    "lucide-react": "^0.468.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
